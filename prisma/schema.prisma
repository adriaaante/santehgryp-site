// Santehgryp e-commerce — data model.
// Core idea: ProductFamily ↔ Variant split powers the variant configurator
// (one product page + selector) while each Variant keeps its own indexable URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Catalog tree ────────────────────────────────────────────────────────
model Category {
  id              String     @id @default(cuid())
  slug            String     @unique
  name            String
  parentId        String?
  parent          Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children        Category[] @relation("CategoryTree")
  depth           Int        @default(0)
  sortOrder       Int        @default(0)
  imageUrl        String?
  // SEO
  metaTitle       String?
  metaDescription String?
  seoText         String? // HTML block rendered at the bottom of the category page

  families ProductFamily[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([slug])
}

model Brand {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  logoUrl     String?
  description String?
  families    ProductFamily[]

  @@index([slug])
}

// ── Product family = the "product page" (groups variants) ───────────────
model ProductFamily {
  id              String  @id @default(cuid())
  slug            String  @unique
  name            String
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  brandId         String?
  brand           Brand?   @relation(fields: [brandId], references: [id])
  descriptionHtml String?
  mainImageUrl    String?
  aggregateRating Float?
  ratingCount     Int?

  // Ordered axes that distinguish variants, drives the configurator UI.
  // e.g. [{ "key":"width", "label":"Ширина", "unit":"мм" }, { "key":"color", "label":"Цвет" }]
  variantAxes Json @default("[]")

  // SEO overrides (fallbacks computed from name/category when null)
  metaTitle       String?
  metaDescription String?

  defaultVariantId String?  @unique
  defaultVariant   Variant? @relation("DefaultVariant", fields: [defaultVariantId], references: [id])

  variants   Variant[]               @relation("FamilyVariants")
  images     ProductImage[]
  attributes ProductAttributeValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([brandId])
}

enum Availability {
  IN_STOCK
  ON_ORDER
  OUT_OF_STOCK
}

// ── Variant = the buyable SKU (own indexable URL) ───────────────────────
model Variant {
  id        String        @id @default(cuid())
  familyId  String
  family    ProductFamily @relation("FamilyVariants", fields: [familyId], references: [id], onDelete: Cascade)
  sku       String        @unique
  slug      String        @unique
  price     Decimal       @db.Decimal(12, 2)
  oldPrice  Decimal?      @db.Decimal(12, 2)
  currency  String        @default("RUB")
  availability Availability @default(IN_STOCK)
  stockQty  Int?
  barcode   String?
  weight    Float?

  // Concrete value per axis, e.g. { "width": "200", "color": "white" }
  axisValues Json @default("{}")

  images          ProductImage[]
  attributeValues VariantAttributeValue[]
  orderItems      OrderItem[]
  defaultFor      ProductFamily?          @relation("DefaultVariant")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([familyId])
  @@index([sku])
}

// ── Attributes / facets ─────────────────────────────────────────────────
enum AttributeType {
  ENUM
  NUMBER
  BOOL
  TEXT
}

model Attribute {
  id            String        @id @default(cuid())
  code          String        @unique
  name          String
  unit          String?
  type          AttributeType @default(ENUM)
  isFilterable  Boolean       @default(true)
  isVariantAxis Boolean       @default(false)
  sortOrder     Int           @default(0)

  values          AttributeValue[]
  familyValues    ProductAttributeValue[]
  variantValues   VariantAttributeValue[]
}

model AttributeValue {
  id          String    @id @default(cuid())
  attributeId String
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String
  slug        String

  @@unique([attributeId, value])
  @@index([attributeId])
}

model ProductAttributeValue {
  id          String        @id @default(cuid())
  familyId    String
  family      ProductFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   Attribute     @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String

  @@unique([familyId, attributeId])
  @@index([attributeId, value])
}

model VariantAttributeValue {
  id          String    @id @default(cuid())
  variantId   String
  variant     Variant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String

  @@unique([variantId, attributeId])
  @@index([attributeId, value])
}

// ── Images ──────────────────────────────────────────────────────────────
model ProductImage {
  id        String         @id @default(cuid())
  familyId  String?
  family    ProductFamily? @relation(fields: [familyId], references: [id], onDelete: Cascade)
  variantId String?
  variant   Variant?       @relation(fields: [variantId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int            @default(0)
  width     Int?
  height    Int?

  @@index([familyId])
  @@index([variantId])
}

// ── Orders (request-style checkout for MVP) ─────────────────────────────
enum OrderStatus {
  NEW
  CONFIRMED
  CANCELLED
  DONE
}

model Order {
  id             String      @id @default(cuid())
  number         String      @unique
  customerName   String
  phone          String
  email          String?
  deliveryMethod String?
  address        String?
  comment        String?
  status         OrderStatus @default(NEW)
  total          Decimal     @db.Decimal(12, 2)
  metricaClientId String?
  items          OrderItem[]
  createdAt      DateTime    @default(now())

  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId     String?
  variant       Variant? @relation(fields: [variantId], references: [id])
  nameSnapshot  String
  skuSnapshot   String
  priceSnapshot Decimal @db.Decimal(12, 2)
  qty           Int

  @@index([orderId])
}
