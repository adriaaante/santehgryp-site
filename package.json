{
  "name": "santehgryp-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate && (prisma db push --accept-data-loss --skip-generate && tsx prisma/seed.ts || echo 'DB not linked yet — building without data') && next build",
    "start:railway": "(prisma db push --accept-data-loss --skip-generate && tsx prisma/seed.ts) || echo 'DB not ready — starting web anyway'; next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "search:reindex": "tsx scripts/reindex-search.ts",
    "scrape": "tsx scraper/src/index.ts",
    "test": "vitest run"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "clsx": "^2.1.1",
    "meilisearch": "^0.45.0",
    "next": "^15.5.19",
    "nodemailer": "^9.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "cheerio": "^1.0.0",
    "cyrillic-to-translit-js": "^3.2.1",
    "got": "^14.4.5",
    "p-queue": "^8.0.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
